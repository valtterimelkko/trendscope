{
  "version": "1.0",
  "template": "analytics-dashboard",
  "totalSlots": 58,
  "slots": {
    "landing": {
      "hero.headline": {
        "type": "headline",
        "maxLength": 80,
        "placeholder": "Simple analytics for modern teams",
        "description": "Main headline on landing page hero section"
      },
      "hero.subheadline": {
        "type": "body",
        "maxLength": 200,
        "placeholder": "Get the insights you need without the complexity. Privacy-friendly, lightweight, and beautiful analytics for your website.",
        "description": "Supporting text below the headline"
      },
      "cta.primary": {
        "type": "button",
        "maxLength": 30,
        "placeholder": "Start Free Trial",
        "description": "Primary call-to-action button text"
      },
      "cta.secondary": {
        "type": "button",
        "maxLength": 30,
        "placeholder": "View Demo",
        "description": "Secondary call-to-action button text"
      },
      "features.title": {
        "type": "section_title",
        "maxLength": 60,
        "placeholder": "Everything you need, nothing you don't",
        "description": "Features section heading"
      },
      "features.subtitle": {
        "type": "body",
        "maxLength": 150,
        "placeholder": "Built for simplicity and speed. Get meaningful insights in seconds.",
        "description": "Features section supporting text"
      },
      "features.items": {
        "type": "array",
        "minItems": 3,
        "maxItems": 6,
        "itemType": {
          "title": { "type": "feature_title", "maxLength": 40 },
          "description": { "type": "body", "maxLength": 120 }
        },
        "default": [
          { "title": "Lightning Fast", "description": "Our script is under 1KB. Your site stays fast while you get all the insights." },
          { "title": "Privacy First", "description": "No cookies, no personal data. GDPR, CCPA, and PECR compliant out of the box." },
          { "title": "Share Publicly", "description": "Make your dashboard public with one click. Build trust with transparency." }
        ]
      },
      "pricing.title": {
        "type": "section_title",
        "maxLength": 60,
        "placeholder": "Simple, transparent pricing",
        "description": "Pricing section heading"
      },
      "pricing.subtitle": {
        "type": "body",
        "maxLength": 150,
        "placeholder": "Pay based on your usage. No hidden fees.",
        "description": "Pricing section supporting text"
      },
      "footer.tagline": {
        "type": "body",
        "maxLength": 100,
        "placeholder": "Privacy Friendly | GDPR Compliant",
        "description": "Footer trust badges/tagline"
      }
    },
    "dashboard": {
      "subtitle": {
        "type": "body",
        "maxLength": 80,
        "placeholder": "Overview of your website analytics",
        "description": "Dashboard page subtitle"
      },
      "empty.title": {
        "type": "empty_state",
        "context": "first_time_user",
        "maxLength": 60,
        "placeholder": "No data yet",
        "description": "Empty state title when no analytics data exists"
      },
      "empty.description": {
        "type": "body",
        "maxLength": 150,
        "placeholder": "Add the tracking code to your website to start seeing analytics.",
        "description": "Empty state description"
      },
      "empty.cta": {
        "type": "button",
        "maxLength": 30,
        "placeholder": "Get Tracking Code",
        "description": "Empty state call-to-action"
      }
    },
    "auth": {
      "login.title": {
        "type": "headline",
        "maxLength": 40,
        "placeholder": "Welcome back",
        "description": "Login page title"
      },
      "login.subtitle": {
        "type": "body",
        "maxLength": 100,
        "placeholder": "Sign in to view your analytics",
        "description": "Login page subtitle"
      },
      "signup.title": {
        "type": "headline",
        "maxLength": 40,
        "placeholder": "Start your free trial",
        "description": "Signup page title"
      },
      "signup.subtitle": {
        "type": "body",
        "maxLength": 100,
        "placeholder": "No credit card required. 14 days free.",
        "description": "Signup page subtitle"
      }
    },
    "errors": {
      "generic.title": {
        "type": "error",
        "tone": "helpful",
        "maxLength": 60,
        "placeholder": "Something went wrong",
        "description": "Generic error title"
      },
      "generic.message": {
        "type": "error",
        "tone": "helpful",
        "maxLength": 200,
        "placeholder": "We're sorry, but something unexpected happened. Please try again or contact support if the problem persists.",
        "description": "Generic error message"
      },
      "network.title": {
        "type": "error",
        "tone": "reassuring",
        "maxLength": 60,
        "placeholder": "Connection issue",
        "description": "Network error title"
      },
      "network.message": {
        "type": "error",
        "tone": "reassuring",
        "maxLength": 200,
        "placeholder": "We couldn't connect to the server. Please check your internet connection and try again.",
        "description": "Network error message"
      },
      "notfound.title": {
        "type": "error",
        "tone": "friendly",
        "maxLength": 60,
        "placeholder": "Page not found",
        "description": "404 error title"
      },
      "notfound.message": {
        "type": "error",
        "tone": "friendly",
        "maxLength": 200,
        "placeholder": "The page you're looking for doesn't exist or has been moved.",
        "description": "404 error message"
      }
    },
    "settings": {
      "general.title": {
        "type": "headline",
        "maxLength": 40,
        "placeholder": "General Settings",
        "description": "General settings page title"
      },
      "team.title": {
        "type": "headline",
        "maxLength": 40,
        "placeholder": "Team Settings",
        "description": "Team settings page title"
      },
      "billing.title": {
        "type": "headline",
        "maxLength": 40,
        "placeholder": "Billing",
        "description": "Billing settings page title"
      }
    },
    "notifications": {
      "success.saved": {
        "type": "body",
        "tone": "positive",
        "maxLength": 50,
        "placeholder": "Changes saved successfully",
        "description": "Success toast after saving"
      },
      "success.copied": {
        "type": "body",
        "tone": "positive",
        "maxLength": 50,
        "placeholder": "Copied to clipboard",
        "description": "Success toast after copying"
      },
      "info.sending": {
        "type": "body",
        "tone": "neutral",
        "maxLength": 50,
        "placeholder": "Sending...",
        "description": "Loading state for async actions"
      }
    },
    "sites": {
      "title": {
        "type": "section_title",
        "maxLength": 30,
        "placeholder": "Your Sites",
        "description": "Sites page main heading"
      },
      "subtitle": {
        "type": "body",
        "maxLength": 80,
        "placeholder": "Manage your websites and analytics properties",
        "description": "Sites page description"
      },
      "addSite.button": {
        "type": "button",
        "maxLength": 20,
        "placeholder": "Add Site",
        "description": "Add new site button"
      },
      "addSite.title": {
        "type": "section_title",
        "maxLength": 40,
        "placeholder": "Add a new site",
        "description": "Add site modal title"
      },
      "addSite.domainLabel": {
        "type": "body",
        "maxLength": 20,
        "placeholder": "Domain",
        "description": "Domain input label"
      },
      "addSite.domainPlaceholder": {
        "type": "body",
        "maxLength": 30,
        "placeholder": "example.com",
        "description": "Domain input placeholder"
      },
      "empty.title": {
        "type": "section_title",
        "maxLength": 40,
        "placeholder": "No sites yet",
        "description": "Empty state heading"
      },
      "empty.description": {
        "type": "body",
        "maxLength": 100,
        "placeholder": "Add your first website to start tracking analytics",
        "description": "Empty state description"
      }
    }
  }
}
