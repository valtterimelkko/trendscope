{
  "name": "productivity-tool",
  "displayName": "Productivity Tool",
  "description": "Fast, keyboard-first SaaS template for task management and team collaboration",
  "version": "1.0.0",
  "category": "productivity",
  "personality": "efficient",
  "authStyle": {
